# --- LLM provider ---
# openrouter | groq | google | openai | anthropic | openai_compatible
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_key_here

# For z.ai-direct (guaranteed GLM-5.2 prompt caching), use openai_compatible:
# LLM_PROVIDER=openai_compatible
# OPENAI_COMPAT_BASE_URL=https://api.z.ai/api/paas/v4
# OPENAI_COMPAT_API_KEY=your_zai_key_here

# Optional model overrides (defaults per provider live in src/config.py)
# REASONING_MODEL=z-ai/glm-5.2
# FAST_MODEL=google/gemma-4-26b-a4b-it

# --- Web search (PESTEL / competitor / trend) ---
TAVILY_API_KEY=your_tavily_key_here

# --- Paths (Docker compose overrides these to /app/data …) ---
RBI_DATA_PATH=./data
CHROMA_DB_PATH=./data/chroma_db

# HuggingFace cache (embedding + reranker models). First Ask/ingest downloads ~1–2GB.
# HF_HOME=./.cache/huggingface

# --- Slack (optional; UI paste also works — no .env required) ---
# Outbound alerts:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T…/B…/…
# Inbound Ask AI (Socket Mode recommended for local Docker):
# SLACK_BOT_TOKEN=xoxb-…
# SLACK_APP_TOKEN=xapp-…   # connections:write
# SLACK_SIGNING_SECRET=…   # only for HTTP /api/slack/events + /commands
# SLACK_SKIP_VERIFY=false

# --- Optional toggles (see src/config.py) ---
# CAG_ENABLED=true
# RERANK_ENABLED=true
# HYBRID_ENABLED=true
# CS_AUTO_INGEST=false
# SHOWCASE_ALL_AGENTS=false   # true = force every specialist agent (demo mesh)
# COMPETITOR_BUDGET_SECONDS=120
